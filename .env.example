# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/huaweiconnect"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Huawei Health Kit OAuth
HUAWEI_CLIENT_ID="your-huawei-app-id"
HUAWEI_CLIENT_SECRET="your-huawei-app-secret"

# Encryption key for Huawei OAuth tokens at rest
ENCRYPTION_SECRET="generate-with-openssl-rand-base64-32"

# Optional: OAuth providers for app login
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# Optional: Email magic link
EMAIL_SERVER="smtp://user:password@smtp.example.com:587"
EMAIL_FROM="noreply@yourdomain.com"

# Cron secret (use in Authorization header when calling /api/cron)
CRON_SECRET="generate-with-openssl-rand-hex-32"
